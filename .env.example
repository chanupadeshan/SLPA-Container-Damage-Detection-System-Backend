DEBUG=True
SECRET_KEY=replace-this-with-a-long-random-secret
API_KEY=

# Hosts / CORS
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database: sqlite (default) or mysql
DB_ENGINE=sqlite
# DB_ENGINE=mysql
# DB_NAME=slpa_container_detection
# DB_USER=root
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=3306

# Set to True only when the app is behind HTTPS.
SECURE_SSL_REDIRECT=False

# Upload and OCR/ML safety limits.
MAX_IMAGE_UPLOAD_BYTES=8388608
MAX_IMAGE_PIXELS=20000000
MAX_IMAGE_WIDTH=6000
MAX_IMAGE_HEIGHT=6000
DETECT_THROTTLE_RATE=10/min
OCR_THROTTLE_RATE=20/min
